COCHL_PROJECT_KEY=replace-with-your-cochl-project-key
# End-to-end worker deadlines for live chunks and standalone recordings, plus
# the connect/read timeout used for individual Cochl HTTP/SSE socket operations.
# All values are finite positive seconds and changes require a backend restart.
COCHL_LIVE_TIMEOUT_SEC=20
COCHL_RECORDING_TIMEOUT_SEC=900
COCHL_SOCKET_TIMEOUT_SEC=30
# When ffmpeg is available, send a provider-only mono Ogg Vorbis copy while
# preserving the captured 48 kHz sample rate. This is a transport compression
# choice, not a Cloud API sample-rate requirement; the PCM WAV remains intact.
COCHL_LIVE_TRANSPORT_COMPRESSION=true
# Reuse one HTTPS connection per live-provider worker and poll completed results
# promptly. Set false to fall back to the pinned SDK's slower legacy transport.
COCHL_LIVE_PERSISTENT_CONNECTIONS=true
COCHL_ENABLE_SOUND_EVENT_DETECTION=true
COCHL_ENABLE_SPEECH_ANALYSIS=false
COCHL_ENABLE_AUDIO_INSIGHTS=false
MAX_UPLOAD_MB=25

# GCS upload is disabled until all three target values are set in `.env`.
# The per-install uploader id is generated automatically when left unset.
# GCS_PROJECT_ID=
# GCS_BUCKET_NAME=
# GCS_OBJECT_PREFIX=
# GCS_UPLOADER_ID=
# Optional for service-account ADC. Prefer `gcloud auth application-default login`
# for local user credentials; never commit the referenced JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Live data collection: keep only meaningful (non-silent, non-speech) audio,
# merged into segments of COCHL_COLLECTION_MIN_SEGMENT_SEC..MAX_SEGMENT_SEC
# under recordings/collected/. Short detections are padded with surrounding
# background audio up to the minimum length.
# Set COCHL_COLLECTION_ENABLED=false to fall back to keeping every live chunk.
COCHL_COLLECTION_ENABLED=true
COCHL_COLLECTION_CONFIDENCE_THRESHOLD=0.5
COCHL_COLLECTION_MIN_SEGMENT_SEC=5
COCHL_COLLECTION_MAX_SEGMENT_SEC=20
# Nearby detections are merged until silence lasts this long. The open segment
# is then written while recording continues.
COCHL_COLLECTION_SILENCE_CLOSE_SEC=3
# Final segment curation limits. Rejected candidates leave only one compact
# decisions.jsonl record and do not create per-segment audio/JSON files.
COCHL_COLLECTION_MAX_SELECTED_SEGMENTS=600
COCHL_COLLECTION_MAX_SELECTED_DURATION_SEC=3600
COCHL_COLLECTION_MAX_SELECTED_AUDIO_MB=512
COCHL_COLLECTION_REPEAT_COOLDOWN_SEC=600
COCHL_COLLECTION_MAX_QUOTA_LABEL_SHARE=0.30
# Comma-separated, case-insensitive taxonomy tokens to exclude for privacy.
# Known inflections such as whispering/singing are matched by a small alias set;
# arbitrary substrings are not (so Reversing_beep does not match sing).
COCHL_COLLECTION_EXCLUDE_LABEL_KEYWORDS=speech,whisper,sing,conversation,narration,talk
